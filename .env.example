# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── AI chat (homepage chatbot) ─────────────────────────────────
DEFAULT_AI_API_KEY=       # API key for the LLM gateway
DEFAULT_AI_BASE_URL=      # e.g. https://agent-gw.kimi.com/coding/v1
DEFAULT_AI_MODEL=         # e.g. kimi:kimi-k2.5
